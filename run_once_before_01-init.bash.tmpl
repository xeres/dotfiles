#!/usr/bin/env bash

set -e

{{ if eq .chezmoi.osRelease.id "ubuntu" -}}
if [ ! -f /etc/apt/apt.conf.d/00-no-install-recommends ]; then
    sudo tee /etc/apt/apt.conf.d/00-no-install-recommends << __EOF__ >/dev/null
APT::Install-Recommends 0;
APT::Install-Suggests 0;
__EOF__
fi

sudo apt-get update
sudo apt-get upgrade -y


sudo apt-get install -y \
    zsh \
    zip unzip \
    tofrodos \
    wslu \
    make build-essential libssl-dev zlib1g-dev \
    libbz2-dev libreadline-dev libsqlite3-dev wget curl llvm \
    libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev
{{ else if eq .chezmoi.osRelease.id "amzn" -}}
if [ ! -f /etc/yum.conf ]; then
    sudo sed '^\[main\]/ainstall_weak_deps=false' /etc/yum.conf
fi
{{ end -}}

if [ $(basename "$SHELL") != "zsh" ]; then
    sudo chsh -s $(which zsh) ${USER}
fi

if [ ! -d ~/.tmux/plugins/tpm ]; then
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm

    cat /dev/null | tmux -C
    tmux run-shell ~/.tmux/plugins/tpm/bindings/install_plugins
    tmux kill-session -t $(tmux list-sessions -F '#{session_id}' | tail -1) || :
fi
